{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug"
        },
        {
            "name": "Flutter: Run all tests",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "program": "${workspaceFolder}/test/",
            "args": [
                "--coverage"
            ]
        },
        {
            "name": "Flutter: Attach to Device",
            "request": "attach",
            "type": "dart",
            "deviceId": "flutter-tester"
        }
    ]
}